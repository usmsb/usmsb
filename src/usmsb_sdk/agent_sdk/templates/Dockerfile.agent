# Agent SDK Dockerfile
# This Dockerfile creates a containerized agent that auto-registers with the platform

# Base image with Python 3.11
FROM python:3.11-slim as base

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN useradd --create-home --shell /bin/bash agent

# Set working directory
WORKDIR /app

# Copy requirements first for caching
COPY requirements-agent.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements-agent.txt

# Copy application code
COPY --chown=agent:agent . .

# Switch to non-root user
USER agent

# Expose default ports
# 8000: HTTP API
# 8765: WebSocket
# 9000: P2P
EXPOSE 8000 8765 9000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Default command
CMD ["python", "-m", "agent.main"]

# =====================================================
# Development Stage
# =====================================================
FROM base as development

# Install development dependencies
USER root
RUN pip install --no-cache-dir \
    pytest \
    pytest-asyncio \
    pytest-cov \
    black \
    flake8 \
    mypy

USER agent

# Mount point for development
VOLUME ["/app"]

# Development command with auto-reload
CMD ["python", "-m", "agent.main", "--reload"]

# =====================================================
# Production Stage
# =====================================================
FROM base as production

# Production optimizations
ENV PYTHONOPTIMIZE=1

# Copy only necessary files
COPY --chown=agent:agent src/ /app/src/
COPY --chown=agent:agent config/ /app/config/
COPY --chown=agent:agent agent/ /app/agent/

# Production command with gunicorn
CMD ["gunicorn", "--bind", "0.0.0.0:8000", "--workers", "4", "--worker-class", "uvicorn.workers.UvicornWorker", "agent.main:app"]
