# ====================================
# Supply Chain Demo 环境变量配置
# ====================================

# 平台配置
PLATFORM_URL=http://localhost:8080
PLATFORM_API_KEY=your_api_key_here

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# 数据库配置（可选）
DATABASE_URL=postgresql://user:password@localhost:5432/supply_chain

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent 通用配置
AGENT_TIMEOUT=30
AGENT_RETRY_COUNT=3
AGENT_HEARTBEAT_INTERVAL=30

# SupplierAgent 配置
SUPPLIER_AGENT_NAME=supplier_agent_001
SUPPLIER_AGENT_PORT=8001

# BuyerAgent 配置
BUYER_AGENT_NAME=buyer_agent_001
BUYER_AGENT_PORT=8002

# PredictorAgent 配置
PREDICTOR_AGENT_NAME=predictor_agent_001
PREDICTOR_AGENT_PORT=8003
PREDICTOR_MODEL_PATH=/app/models/price_predictor.pkl

# MatchAgent 配置
MATCH_AGENT_NAME=match_agent_001
MATCH_AGENT_PORT=8004

# 安全配置
SECRET_KEY=your_secret_key_here
ENABLE_TLS=false
TLS_CERT_PATH=/app/certs/cert.pem
TLS_KEY_PATH=/app/certs/key.pem
