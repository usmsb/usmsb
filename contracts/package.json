{
  "name": "vibe-contracts",
  "version": "1.0.0",
  "description": "VIBE Token smart contracts for USMSB ecosystem",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "deploy:base:testnet": "hardhat run scripts/deploy.js --network baseSepolia",
    "deploy:localhost": "hardhat run scripts/deploy.js --network localhost",
    "verify": "hardhat run scripts/verify.js",
    "interact": "hardhat run scripts/interact.js",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "lint": "solhint 'src/**/*.sol'",
    "lint:fix": "solhint 'src/**/*.sol' --fix"
  },
  "keywords": [
    "solidity",
    "ethereum",
    "vibe",
    "usmsb",
    "erc20",
    "staking",
    "vesting",
    "sbt"
  ],
  "author": "VIBE Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.2.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.1.1",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0"
  }
}
